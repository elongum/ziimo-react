# Kopier denne filen til .env og fyll inn verdiene

PORT=3001

# Generer med: node -e "require('crypto').randomBytes(48).then ? undefined : console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=

# Kommaseparert liste over tillatte frontend-origins
# Lokalt:      http://localhost:5173
# Produksjon:  https://ziimo-react.vercel.app,http://localhost:5173
CORS_ORIGIN=http://localhost:5173

# Lokalt: ./db/ziimo.db
# Render med persistent disk: /data/ziimo.db
DB_PATH=./db/ziimo.db
